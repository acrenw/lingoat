{
  "manifest_version": 3,
  "name": "LinGOAT",
  "version": "3.0.0",
  "description": "Learn languages from doom scrolling and binging shows.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "https://api.groq.com/*",
    "https://translate.googleapis.com/*",
    "https://api.mymemory.translated.net/*",
    "https://jisho.org/*",
    "https://en.wiktionary.org/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://translate.googleapis.com https://api.mymemory.translated.net https://jisho.org https://en.wiktionary.org https://api.groq.com"
  },
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "css": ["src/content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/goat.png",
      "48": "icons/goat.png",
      "128": "icons/goat.png"
    }
  },
  "icons": {
    "16": "icons/goat.png",
    "48": "icons/goat.png",
    "128": "icons/goat.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/content/*", "src/onboarding/*", "src/offscreen/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
